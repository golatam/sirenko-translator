{
  "name": "translator-widget",
  "version": "1.0.4",
  "description": "Lightweight popup translator using Claude API — double Cmd+C to translate",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac --dir",
    "dmg": "electron-builder --mac",
    "deploy": "electron-builder --mac --dir && rm -rf /Applications/Translator.app && cp -R dist/mac-arm64/Translator.app /Applications/Translator.app && echo '✓ Installed to /Applications/Translator.app'",
    "build:update:js": "node scripts/build-update.js js",
    "build:update:full": "electron-builder --mac --dir && node scripts/build-update.js full"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@xenova/transformers": "^2.17.2",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.kirill.translator",
    "productName": "Translator",
    "files": [
      "**/*",
      "!**/*.md",
      "!.git/**"
    ],
    "asarUnpack": [
      "node_modules/@xenova/**",
      "node_modules/onnxruntime-node/**",
      "models/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dir",
      "identity": null
    },
    "asar": false
  }
}
